@startuml APMS_Activity3_Knowledge
skinparam swimlane {
  WrapTitle false
}

|#E8F4FD|Student|
start
:Request knowledge access from documents;

|#E8FDE8|APMS System|
:Limit readable scope to documents owned by the user,\nshared with the user, or public;

|Student|
if (Requested capability?) then (Public document listing)
  if (Discovery scope?) then (Academic-profile suggestions)
    |APMS System|
    :Prioritize public documents from the profile Curriculum,\nthen other public documents;
    |Student|
  else (Full public listing)
    :Provide major, semester, and course filters;
    |APMS System|
    :Return public document list;
    |Student|
  endif
elseif (Semantic document search) then
  :Provide search phrase or question;
  |APMS System|
  :Run semantic search within readable scope;
  |Student|
else (AI assistant conversation session)
  :Define AI context: all documents / folder / document;
  :Define assistant mode: Q&A / Summary / FAQ / Study guide;
  :Submit question;
  |APMS System|
  if (Daily AI message quota available?\nmax 50/day) then (no)
    :Reject request and ask user to try again tomorrow;
    |Student|
  else (yes)
    :Generate concise conversational answer\nwith source citations;
    if (Assistant mode is Q&A?) then (yes)
      :Include suggested follow-up questions;
    else (no)
      :Do not include follow-up questions;
    endif
    |Student|
  endif
endif

:View details, download documents, or read AI answer\n(read-only for documents not owned by the user);

if (Continue knowledge access?) then (yes)
  :Return to capability selection;
  detach
else (no)
  stop
endif

@enduml
