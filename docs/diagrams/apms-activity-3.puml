@startuml APMS_Activity3_Knowledge
skinparam swimlane {
  WrapTitle false
}
skinparam activity {
  BackgroundColor #FEFECE
  BorderColor #333333
}

|#E8F4FD|Student|
start
:Request knowledge access from documents;

|#E8FDE8|APMS System|
:Limit readable scope to documents owned by the user,\nshared with the user, or public;

|Student|
if (Requested capability?) then (Public library)
  if (Discovery scope?) then (Profile suggestions)
    |APMS System|
    :Rank profile-Curriculum public docs first\n(profile optional; non-blocking);
  else (Full listing)
    |APMS System|
    :List public docs\n(Curriculum / semester / course filters);
  endif
elseif (Semantic search) then
  :Provide search phrase or question;
  |APMS System|
  :Run semantic search within readable scope;
else (AI assistant chat)
  :Pick context (all / folder / docs)\nand mode (Q&A / Summary / FAQ / Study guide);
  :Submit question;
  |APMS System|
  :Hide sessions with trashed / missing context;
  if (Daily AI quota available?\nmax 50/day) then (yes)
    :Answer from in-scope chunks + citations\n(doc, page, section); follow-ups in Q&A only;
  else (no)
    :Reject and ask to retry tomorrow;
  endif
endif

|Student|
:View / download / read answer\n(read-only if not owner);

if (Continue knowledge access?) then (yes)
  :Return to capability selection;
  detach
else (no)
  stop
endif

@enduml
