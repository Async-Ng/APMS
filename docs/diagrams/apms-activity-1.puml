@startuml APMS_Activity1_Onboarding
skinparam swimlane {
  WrapTitle false
}
skinparam activity {
  BackgroundColor #FEFECE
  BorderColor #333333
}

|#E8F4FD|Student|
start
:Authenticate with Google account;

|#E8FDE8|APMS System|
:Verify allowed email\n(fpt.edu.vn / fe.edu.vn domains or approved exception);
if (Email allowed?) then (no)
  :Reject access with authorization message;
  stop
else (yes)
  :Create or synchronize user account;
  :Return account with academic profile status;
endif

|Student|
:Enter the application;

|APMS System|
if (Academic profile completed?) then (yes)
  :Show profile status **Completed**; <<#PaleGreen>>
  stop
else (no)
  :Prompt to set up academic profile\nand provide active Curriculum options;
endif

|Student|
if (Set up academic profile now?) then (no)
  :Skip for now;
  note right
    Profile stays **Incomplete**.
    App is still usable, but upload and
    library suggestions require a profile.
  end note
  stop
else (yes)
  :Select Curriculum;
  :Submit academic profile update;
endif

|APMS System|
if (Curriculum is active?) then (no)
  :Reject update and require a valid Curriculum;
  |Student|
  :Return to Curriculum selection;
  detach
else (yes)
  :Save academic profile\n(clear any legacy semester/subject data);
  :Set profile status to **Completed**; <<#PaleGreen>>
  stop
endif

@enduml
