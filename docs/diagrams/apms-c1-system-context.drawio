        <mxCell id="student" value="&lt;b&gt;Sinh viên / Người dùng&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size: 11px;&quot;&gt;Quản lý tài liệu học tập, upload tài liệu theo môn học, chia sẻ read-only, tìm kiếm và chat AI&lt;/font&gt;" style="shape=umlActor;verticalLabelPosition=bottom;verticalAlign=top;html=1;outlineConnect=0;fillColor=#f8fafc;strokeColor=#334155;fontSize=12;fontColor=#111827;" vertex="1" parent="1">
