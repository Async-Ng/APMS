        <mxCell id="apms" value="&lt;b&gt;APMS&lt;/b&gt;&lt;br&gt;&lt;b&gt;Academic Personal Management System&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size: 12px;&quot;&gt;Hệ thống quản lý tài liệu học tập cá nhân: lưu trữ, phân loại theo course slot, chia sẻ, public discovery, semantic search và RAG chat có trích dẫn.&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;strokeWidth=2;arcSize=12;shadow=1;fontSize=14;fontColor=#111827;spacing=12;" vertex="1" parent="1">
