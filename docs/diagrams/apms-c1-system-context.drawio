        <mxCell id="note" value="&lt;b&gt;Business invariants&lt;/b&gt;&lt;br&gt;- visibility: private | public; mặc định private&lt;br&gt;- Upload cần courseSlotId; PDF/DOCX/PPTX&lt;br&gt;- 50 MB/file; 500 MB/user&lt;br&gt;- Chat AI: 50 câu hỏi/người dùng/ngày&lt;br&gt;- Share invite: 7 ngày; download URL: 15 phút" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;fontColor=#111827;align=left;spacing=10;" vertex="1" parent="1">
