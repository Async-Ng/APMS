# Google OAuth 2.0 (required for Cognito Google federated IdP)
GOOGLE_CLIENT_ID=replace_with_google_client_id
GOOGLE_CLIENT_SECRET=replace_with_google_client_secret

# Optional: Cognito Hosted UI domain prefix (lowercase, unique per region)
# Default: apms-<aws-account-id>
# COGNITO_DOMAIN_PREFIX=apms-dev

# OAuth callback / logout URLs for Cognito App Client (comma-separated). Add every deploy URL or Cognito returns redirect_mismatch.
# Callback must match web: {NEXT_PUBLIC_APP_URL}/auth/callback — logout: {NEXT_PUBLIC_APP_URL}/login (see web/lib/amplify.ts)
# OAUTH_CALLBACK_URLS=http://localhost:3000/auth/callback,https://your-app.vercel.app/auth/callback,apms://auth/callback
# OAUTH_LOGOUT_URLS=http://localhost:3000/login,https://your-app.vercel.app/login,apms://

# Optional: target AWS account/region (otherwise uses AWS CLI default profile)
# CDK_DEFAULT_ACCOUNT=123456789012
# CDK_DEFAULT_REGION=us-east-1
