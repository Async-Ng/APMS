# Server
PORT=4000
NODE_ENV=development
# Optional: base URL shown in OpenAPI spec (Swagger). Default http://localhost:4000
# PUBLIC_API_BASE_URL=http://localhost:4000

# MongoDB
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority

# Amazon Cognito (outputs from `cdk deploy`)
COGNITO_USER_POOL_ID=replace_with_cognito_user_pool_id
COGNITO_CLIENT_ID=replace_with_cognito_client_id
COGNITO_REGION=ap-southeast-1
# Comma-separated, without @. These domains bypass the admin-managed exact-email allowlist.
ALLOWED_EMAIL_DOMAINS=fpt.edu.vn,fe.edu.vn

# AWS
AWS_REGION=ap-southeast-1
AWS_ACCESS_KEY_ID=replace_with_aws_access_key_id
AWS_SECRET_ACCESS_KEY=replace_with_aws_secret_access_key

# S3
S3_BUCKET_NAME=replace_with_s3_bucket_name

# SES (must verify this sender email/domain in AWS SES console; sandbox mode
# can only send to verified recipient addresses)
SES_FROM_EMAIL=no-reply@example.com

# Public web app URL — used to build share notification / invite links in emails
APP_URL=http://localhost:3000

# Upload limits
MAX_UPLOAD_BYTES=52428800
S3_PRESIGN_EXPIRES_SECONDS=900

# ─────────────────────────────────────────────────────────────────────────────
# Vertex AI — Application Default Credentials
# Setup: docs/post_deploy_setup.md section 5
# ─────────────────────────────────────────────────────────────────────────────
GOOGLE_CLOUD_PROJECT=replace_with_gcp_project_id
GOOGLE_CLOUD_LOCATION=asia-southeast1
# Local dev: path to service account JSON, or use `gcloud auth application-default login`
GOOGLE_APPLICATION_CREDENTIALS=D:\path\to\vertex-sa-key.json
# Render / PaaS: paste entire service account JSON on one line (do not set both)
# GOOGLE_APPLICATION_CREDENTIALS_JSON={"type":"service_account",...}

GEMINI_CHAT_MODEL=gemini-2.5-flash
GEMINI_VISION_MODEL=gemini-2.5-flash
GEMINI_EMBEDDING_MODEL=gemini-embedding-001
GEMINI_EMBEDDING_OUTPUT_DIMENSION=1024
# Process-wide pacing/throttle for embedding calls (shared by all concurrent
# documents/workers — see api/src/services/ai/gemini.provider.ts)
GEMINI_EMBED_MIN_INTERVAL_MS=100
GEMINI_EMBED_TOKENS_PER_MINUTE=200000
EMBED_CONCURRENCY=5
SENTENCE_EMBED_CONCURRENCY=4
GEMINI_MAX_RETRIES=3
GEMINI_RETRY_BASE_MS=1000
# Longer backoff specifically for 429/quota errors (per-minute quota window)
GEMINI_QUOTA_MAX_RETRIES=2
GEMINI_QUOTA_RETRY_BASE_MS=15000

# Document image / vision (OCR + image description via Gemini Vision)
# Set DOC_VISION_ENABLED=false to disable entirely (PDF/DOCX fall back to text-only)
DOC_VISION_ENABLED=true
DOC_VISION_MAX_IMAGES=30
DOC_VISION_SCANNED_TEXT_THRESHOLD=100
DOC_VISION_CONCURRENCY=3

CHAT_DAILY_LIMIT_PER_USER=50
TRASH_RETENTION_DAYS=30

# Background worker poll interval for documents stuck in processing/failed (ms)
DOCUMENT_WORKER_POLL_MS=5000
# Max documents processed concurrently by the worker
DOCUMENT_WORKER_CONCURRENCY=3
