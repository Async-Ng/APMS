# Server
PORT=4000
NODE_ENV=development
# Optional: base URL shown in OpenAPI spec (Swagger). Default http://localhost:4000
# PUBLIC_API_BASE_URL=http://localhost:4000

# MongoDB
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority

# Amazon Cognito (outputs from `cdk deploy`)
COGNITO_USER_POOL_ID=replace_with_cognito_user_pool_id
COGNITO_CLIENT_ID=replace_with_cognito_client_id
COGNITO_REGION=ap-southeast-1

# AWS
AWS_REGION=ap-southeast-1
AWS_ACCESS_KEY_ID=replace_with_aws_access_key_id
AWS_SECRET_ACCESS_KEY=replace_with_aws_secret_access_key

# S3
S3_BUCKET_NAME=replace_with_s3_bucket_name

# Upload limits
MAX_UPLOAD_BYTES=52428800
S3_PRESIGN_EXPIRES_SECONDS=900

# ─────────────────────────────────────────────────────────────────────────────
# AI Provider configuration
# ─────────────────────────────────────────────────────────────────────────────
# Options:
#   local   → Embedding FREE in-process (@xenova/transformers, 384 dims). Chat needs cloud LLM.
#   gemini  → Embedding + chat both via Gemini API (paid or free-tier)
#   bedrock → Embedding + chat via AWS Bedrock (Cohere embed + Nova Micro)
#   auto    → Bedrock first, Gemini fallback (requires GEMINI_API_KEY)
#
# Bedrock: IAM permissions from `cdk deploy` + enable models in Bedrock Model Catalog.
# After switching from local/gemini, rebuild vector index — see scripts/rebuild-vector-index-bedrock.md
AI_PROVIDER=bedrock

# Amazon Bedrock — required when AI_PROVIDER=bedrock (or auto for chat fallback)
BEDROCK_MODEL_ID=apac.amazon.nova-micro-v1:0
BEDROCK_EMBEDDING_MODEL_ID=cohere.embed-english-v3

# Bedrock usage limits (throttle + retry + chat rate limit)
BEDROCK_EMBED_DELAY_MS=200
BEDROCK_MAX_RETRIES=3
BEDROCK_RETRY_BASE_MS=1000
CHAT_DAILY_LIMIT_PER_USER=50

# Google AI Studio: https://aistudio.google.com/apikey
# Only required when AI_PROVIDER=gemini or auto
# GEMINI_API_KEY=replace_with_gemini_api_key
# GEMINI_CHAT_MODEL=gemini-2.5-flash
# GEMINI_EMBEDDING_MODEL=gemini-embedding-001
